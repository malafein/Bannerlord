<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.0.0.9" />
    <PackageReference Include="log4net" Version="2.0.8" />
    <PackageReference Include="Newtonsoft.Json" Version="12.0.3">
      <!-- Game ships Newtonsoft.Json; compile-only reference -->
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="mkdir -p '$(ModDeployPath)'" />
    <Exec Command="mkdir -p '$(ModDataPath)'" />
    <Exec Command="cp '$(OutputPath)$(AssemblyName).dll' '$(ModDeployPath)'" />
    <Exec Command="cp '$(OutputPath)0Harmony.dll' '$(ModDeployPath)'" />
    <Exec Command="cp '$(OutputPath)log4net.dll' '$(ModDeployPath)'" />
    <Exec Command="cp '$(ProjectDir)SubModule.xml' '$(ModRootPath)'" />
    <Exec Command="cp '$(ProjectDir)ModuleData/'* '$(ModDataPath)'" />
    <Message Importance="high" Text="Deployed $(AssemblyName) to Game Folder" />
  </Target>

</Project>
